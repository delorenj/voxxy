# Copy to .env and fill in. Or rely on values already exported in your shell.
DEFAULT_USERNAME=delorenj
DEFAULT_PASSWORD=changeme

# ElevenLabs fallback engine. Omit to disable fallback entirely.
# Stored in 1password DeLoSecrets vault as "ElevenLabs API Key".
ELEVENLABS_API_KEY=
# Default voice id used when a vox voice profile has no elevenlabs_voice_id
# mapping. pNInz6obpgDQGcFmaJgB = "Adam" (deep, calm, broadcast-quality).
ELEVENLABS_DEFAULT_VOICE=pNInz6obpgDQGcFmaJgB
