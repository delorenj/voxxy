#!/usr/bin/env bash
# vox-speak: compatibility shim forwarding to `voxxy speak`.
#
# The real implementation lives in the voxxy CLI (cli/voxxy/commands/speak.py).
# This shim preserves the historical flag surface so existing workflows
# (ssh pipelines, n8n nodes, crontabs) keep working without changes:
#
#   vox-speak "hello"                    # same
#   vox-speak -v rick "hello"            # same
#   echo "hi" | vox-speak                # same
#   vox-speak --raw "hi" > out.wav       # same
#   ssh host vox-speak --raw "hi"        # same, as long as voxxy is on the
#                                        # remote's PATH (or vox-speak is
#                                        # itself a shim on the remote).
#   vox-speak --via host "hi"            # same
#
# Env vars honored:
#   VOX_VOICE, VOX_URL, VOX_PLAYER, VOX_REMOTE_HOST, VOX_REMOTE_BIN
#
# If you want to keep calling this as `vox-speak`, do nothing. If you want the
# new name, call `voxxy speak` directly.

# `exec` replaces this process so Ctrl-C, signals, and exit codes propagate
# cleanly. No bash-layer argument mangling.
exec voxxy speak "$@"
